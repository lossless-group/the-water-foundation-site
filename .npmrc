# Treat this project as standalone — do not try to discover or use the
# parent astro-knots workspace. Critical for Vercel: without this, pnpm
# would error out looking for pnpm-workspace.yaml, and locally it would
# substitute the workspace copy of @lossless-group/lfm instead of the
# published JSR version.
ignore-workspace=true

# JSR registry — required to resolve @jsr/* aliased deps like
# @lossless-group/lfm (published at jsr.io/@lossless-group/lfm and consumed
# via the npm alias `npm:@jsr/lossless-group__lfm@…` in package.json).
# Public registry, no auth token needed — works the same in dev and on Vercel.
@jsr:registry=https://npm.jsr.io

# Enable build scripts for all packages
enable-pre-post-scripts=true

# Allow unsafe permissions for build scripts
unsafe-perm=true

# Auto-install peer dependencies
auto-install-peers=true

# Hoist dependencies to avoid issues with some packages
shamefully-hoist=true

# Don't ignore scripts during installation
ignore-scripts=false

# Allow scripts to run during CI/CD
scripts-prepend-node-path=true

# Disable strict peer dependencies to avoid build failures
strict-peer-dependencies=false
