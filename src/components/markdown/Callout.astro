---
import AstroMarkdown from "./AstroMarkdown.astro";
import { toString } from "mdast-util-to-string";

export interface Props {
  node: any;
  data?: any;
}

const { node, data } = Astro.props as Props;
const attrs = node.attributes || {};
const tone = attrs.type ?? "info";
const title = attrs.title ?? undefined;

function childrenOf(n: any): any[] {
  return Array.isArray(n?.children) ? n.children : [];
}
---

<div class={`ak-callout ak-callout-${tone}`}>
  {title && <div class="ak-callout-title">{title}</div>}
  <div class="ak-callout-body">
    {childrenOf(node).length > 0 ? (
      childrenOf(node).map((child) => (
        <AstroMarkdown node={child} data={data} />
      ))
    ) : (
      <p>{toString(node)}</p>
    )}
  </div>
</div>

<style>
  .ak-callout {
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    border-width: 1px;
    border-style: solid;
  }

  .ak-callout-title {
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .ak-callout-body {
    font-size: 0.95rem;
  }

  .ak-callout-info {
    border-color: rgba(59, 130, 246, 0.4);
    background: rgba(59, 130, 246, 0.06);
  }

  .ak-callout-tip {
    border-color: rgba(34, 197, 94, 0.4);
    background: rgba(34, 197, 94, 0.06);
  }

  .ak-callout-warning {
    border-color: rgba(245, 158, 11, 0.4);
    background: rgba(245, 158, 11, 0.06);
  }

  .ak-callout-danger {
    border-color: rgba(239, 68, 68, 0.4);
    background: rgba(239, 68, 68, 0.06);
  }

  .ak-callout-note {
    border-color: rgba(148, 163, 184, 0.4);
    background: rgba(148, 163, 184, 0.06);
  }

  .ak-callout-success {
    border-color: rgba(34, 197, 94, 0.4);
    background: rgba(34, 197, 94, 0.06);
  }

  .ak-callout-quote {
    border-color: rgba(148, 163, 184, 0.4);
    background: rgba(148, 163, 184, 0.04);
    font-style: italic;
  }

  .ak-callout-example {
    border-color: rgba(168, 85, 247, 0.4);
    background: rgba(168, 85, 247, 0.06);
  }
</style>
