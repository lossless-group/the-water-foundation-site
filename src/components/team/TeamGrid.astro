---
import PersonCard from './PersonCard.astro';

export interface TeamGridProps {
  teamMembers: Array<{
    name: string;
    role: string;
    image: string;
    bio: string;
    socialLinks?: Array<{
      name: string;
      href: string;
    }>;
    className?: string;
    maxWords?: number;
  }>;
  className?: string;
}

const { teamMembers, className = '' } = Astro.props;
---

<div class="relative py-20 bg-gradient-to-r from-cyan-400 via-blue-500 to-indigo-600 overflow-hidden">
  <!-- Clean, smooth background - no additional elements -->
  
  <div class="relative z-10">
    <!-- Team Grid -->
    <div class:list={[
      'grid gap-10',
      'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4',
      'mx-auto max-w-7xl px-4 sm:px-6 lg:px-8',
      className
    ]}>
      {teamMembers.map((member: any, index: number) => (
        <PersonCard 
          key={member.name}
          {...member}
          class={index === 0 ? 'sm:col-span-2 lg:col-span-2 lg:row-span-2' : ''}
        />
      ))}
    </div>
  </div>
</div>
