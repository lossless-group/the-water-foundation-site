---
import SignUpForThis from "../../../components/basics/signups/SignUpForThis.astro"
---

<!-- Hero Section -->
<section class="relative py-20 bg-gradient-to-br from-blue-900 via-indigo-800 to-cyan-900 overflow-hidden">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0">
    <!-- Floating Water Particles -->
    <div class="absolute top-20 left-20 w-4 h-4 bg-cyan-400/60 rounded-full animate-bounce opacity-70"></div>
    <div class="absolute top-40 right-32 w-3 h-3 bg-blue-400/50 rounded-full animate-pulse opacity-60"></div>
    <div class="absolute bottom-32 left-1/4 w-5 h-5 bg-indigo-400/40 rounded-full animate-bounce opacity-50"></div>
    <div class="absolute top-1/2 right-1/3 w-2 h-2 bg-cyan-300/70 rounded-full animate-ping opacity-40"></div>
    
    <!-- Gradient Orbs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-gradient-to-br from-cyan-600/20 to-transparent rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-gradient-to-br from-blue-600/15 to-transparent rounded-full blur-3xl animate-pulse delay-1000"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 text-center">
               <!-- Main Heading -->
           <h1 class="text-5xl md:text-7xl font-bold text-white mb-8 tracking-tight leading-tight">
             <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 to-blue-300">
               PROPOSE YOURSELF
             </span>
           </h1>
           
           <!-- Subtitle -->
           <p class="text-2xl md:text-3xl text-blue-100 mb-12 font-medium max-w-4xl mx-auto leading-relaxed">
             We don't post jobs. We attract <span class="text-cyan-300 font-bold">AMAZING HUMANS</span> who create their own roles.
           </p>
           
           <!-- Key Qualities Grid -->
           <div class="grid md:grid-cols-4 gap-6 mb-16">
             <!-- Mission Fit -->
             <div class="group transform transition-all duration-500 hover:scale-110">
               <div class="bg-gradient-to-br from-cyan-500/20 to-blue-500/20 backdrop-blur-xl border border-cyan-400/30 rounded-2xl p-6 h-full hover:from-cyan-500/30 hover:to-blue-500/30 transition-all duration-500">
                 <div class="w-16 h-16 bg-gradient-to-br from-cyan-400 to-blue-500 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
                   <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                   </svg>
                 </div>
                 <h3 class="text-lg font-bold text-cyan-200 mb-2">MISSION FIT</h3>
                 <p class="text-blue-100 text-sm leading-relaxed">
                   You're passionate about water sustainability and global impact
                 </p>
               </div>
             </div>
             
             <!-- Relentless Drive -->
             <div class="group transform transition-all duration-500 hover:scale-110">
               <div class="bg-gradient-to-br from-blue-500/20 to-indigo-500/20 backdrop-blur-xl border border-blue-400/30 rounded-2xl p-6 h-full hover:from-blue-500/30 hover:to-indigo-500/30 transition-all duration-500">
                 <div class="w-16 h-16 bg-gradient-to-br from-blue-400 to-indigo-500 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
                   <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                   </svg>
                 </div>
                 <h3 class="text-lg font-bold text-blue-200 mb-2">RELENTLESS DRIVE</h3>
                 <p class="text-blue-100 text-sm leading-relaxed">
                   You never give up and push boundaries to achieve the impossible
                 </p>
               </div>
             </div>
             
             <!-- Agile Mindset -->
             <div class="group transform transition-all duration-500 hover:scale-110">
               <div class="bg-gradient-to-br from-indigo-500/20 to-purple-500/20 backdrop-blur-xl border border-indigo-400/30 rounded-2xl p-6 h-full hover:from-indigo-500/30 hover:to-indigo-500/30 transition-all duration-500">
                 <div class="w-16 h-16 bg-gradient-to-br from-indigo-400 to-purple-500 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
                   <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                   </svg>
                 </div>
                 <h3 class="text-lg font-bold text-indigo-200 mb-2">AGILE MINDSET</h3>
                 <p class="text-blue-100 text-sm leading-relaxed">
                   You adapt, learn, and pivot faster than the speed of change
                 </p>
               </div>
             </div>
             
             <!-- Can Do Attitude -->
             <div class="group transform transition-all duration-500 hover:scale-110">
               <div class="bg-gradient-to-br from-purple-500/20 to-pink-500/20 backdrop-blur-xl border border-purple-400/30 rounded-2xl p-6 h-full hover:from-purple-500/30 hover:to-pink-500/30 transition-all duration-500">
                 <div class="w-16 h-16 bg-gradient-to-br from-purple-400 to-pink-500 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
                   <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                   </svg>
                 </div>
                 <h3 class="text-lg font-bold text-purple-200 mb-2">CAN DO ATTITUDE</h3>
                 <p class="text-blue-100 text-sm leading-relaxed">
                   You see solutions where others see problems
                 </p>
               </div>
             </div>
           </div>
           
           <!-- Call to Action -->
           <div class="bg-gradient-to-r from-cyan-500/20 via-blue-500/20 to-indigo-500/20 backdrop-blur-sm border border-cyan-400/30 rounded-3xl p-8 max-w-4xl mx-auto">
             <p class="text-xl text-cyan-200 font-medium leading-relaxed mb-6">
               <span class="text-cyan-300 font-bold text-2xl">READY TO MAKE WAVES?</span>
               <br>
               If you fit this description, you can probably propose to us roles and work that we can't even imagine yet.
             </p>
             <p class="text-lg text-blue-100 font-semibold">
               <span class="text-cyan-300">WE'VE BEEN WAITING TO HEAR FROM YOU!</span>
             </p>
           </div>
  </div>
</section>

<!-- Propose Form Section -->
<section class="relative py-20 bg-gradient-to-br from-slate-900 via-blue-900 to-cyan-900 overflow-hidden">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0">
    <!-- Floating Water Particles -->
    <div class="absolute top-20 left-20 w-3 h-3 bg-cyan-400/40 rounded-full animate-bounce opacity-60"></div>
    <div class="absolute top-40 right-32 w-2 h-2 bg-blue-400/40 rounded-full animate-pulse opacity-40"></div>
    <div class="absolute bottom-32 left-1/4 w-4 h-4 bg-indigo-400/40 rounded-full animate-bounce opacity-50"></div>
    
    <!-- Gradient Orbs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-gradient-to-br from-cyan-600/10 to-transparent rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-gradient-to-br from-blue-600/10 to-transparent rounded-full blur-3xl animate-pulse delay-1000"></div>
  </div>

           <div class="relative z-10 max-w-6xl mx-auto px-6 text-center">
           <h2 class="text-4xl md:text-5xl font-bold mb-8 tracking-wide text-cyan-300">
             PROPOSE YOUR VISION
           </h2>
           <p class="text-xl text-blue-100 max-w-3xl mx-auto mb-12 leading-relaxed">
             Tell us how you can help change the world through water innovation. 
             <span class="text-cyan-300 font-bold">We're listening.</span>
           </p>
           
           <div class="max-w-2xl mx-auto">
             <SignUpForThis
               title="PROPOSE YOURSELF"
               description="Share your vision and how you can contribute to water sustainability!"
               buttonText="SEND PROPOSAL NOW"
               className="bg-gradient-to-br from-cyan-500/20 to-blue-500/20 border-cyan-400/50"
             />
           </div>
           
           <!-- Additional CTA -->
           <div class="mt-12 text-center">
             <p class="text-lg text-blue-100 mb-6">
               <span class="text-cyan-300 font-bold">Don't wait for permission.</span> 
               <span class="text-blue-200">Create your own opportunity.</span>
             </p>
             <div class="flex flex-col sm:flex-row gap-4 justify-center">
               <a href="/our-fellowship-program" class="bg-gradient-to-r from-cyan-500 to-blue-500 hover:from-cyan-600 hover:to-blue-600 text-white font-bold px-8 py-4 rounded-xl transition-all duration-300 transform hover:scale-105 hover:shadow-lg text-lg">
                 Explore Fellowships
               </a>
               <a href="/events" class="bg-gradient-to-r from-blue-500 to-indigo-500 hover:from-blue-600 hover:to-indigo-600 text-white font-bold px-8 py-4 rounded-xl transition-all duration-300 transform hover:scale-105 hover:shadow-lg text-lg">
                 Join Events
               </a>
             </div>
           </div>
  </div>
</section>