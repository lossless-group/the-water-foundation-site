---
import BaseThemeLayout from '../layouts/BaseThemeLayout.astro';
import AnimatedWaterBackground from '../components/ui/AnimatedWaterBackground.astro';
---

<BaseThemeLayout title="Events - The Water Foundation">
  <main class="overflow-x-hidden">
    <!-- Hero Section -->
    <section class="relative py-32 bg-gradient-to-br from-blue-950 via-blue-900 to-indigo-900 overflow-hidden">
      <!-- Animated Water Background -->
      <AnimatedWaterBackground intensity="moderate" pattern="flowing" />
      
      <div class="relative z-10 max-w-6xl mx-auto px-6 text-center">
        <h1 class="text-5xl md:text-6xl font-light text-white mb-6 tracking-wide leading-tight">
          Water <span class="text-cyan-300 font-normal">Events</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-blue-100 max-w-4xl mx-auto leading-relaxed font-light">
          Join us at conferences, workshops, and community gatherings that are shaping the future of water innovation
        </p>
        
        <!-- Decorative Element -->
        <div class="flex justify-center mt-8">
          <div class="w-24 h-1 bg-gradient-to-r from-transparent via-cyan-400 to-transparent"></div>
        </div>
      </div>
    </section>

    <!-- Events Gallery Section -->
    <section class="relative py-20 bg-gradient-to-br from-blue-900 via-indigo-800 to-blue-800 overflow-hidden">
      <!-- Animated Water Background -->
      <AnimatedWaterBackground intensity="subtle" pattern="clustered" />
      
      <div class="relative z-10 max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-medium mb-6 tracking-wide text-cyan-300">
            Event Gallery
          </h2>
          <p class="text-lg text-blue-100 max-w-3xl mx-auto">
            Capturing moments from our water innovation events, conferences, and community gatherings
          </p>
        </div>

        <!-- Gallery Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Event Card 1 -->
          <div class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-cyan-500/20 to-blue-600/20 backdrop-blur-sm border border-cyan-400/30 hover:border-cyan-400/50 transition-all duration-500 hover:scale-105">
            <div class="aspect-[4/3] bg-gradient-to-br from-cyan-400/30 to-blue-500/30 flex items-center justify-center">
              <svg class="w-16 h-16 text-cyan-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-semibold text-cyan-200 mb-2">Water Innovation Summit 2024</h3>
              <p class="text-blue-100 text-sm mb-4">Global conference bringing together water innovators, investors, and policymakers</p>
              <div class="flex items-center text-cyan-300 text-sm">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                March 15-17, 2024
              </div>
            </div>
          </div>

          <!-- Event Card 2 -->
          <div class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-indigo-500/20 to-purple-600/20 backdrop-blur-sm border border-indigo-400/30 hover:border-indigo-400/50 transition-all duration-500 hover:scale-105">
            <div class="aspect-[4/3] bg-gradient-to-br from-indigo-400/30 to-purple-500/30 flex items-center justify-center">
              <svg class="w-16 h-16 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-semibold text-indigo-200 mb-2">Community Water Workshop</h3>
              <p class="text-blue-100 text-sm mb-4">Hands-on workshop teaching sustainable water practices to local communities</p>
              <div class="flex items-center text-indigo-300 text-sm">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                April 22, 2024
              </div>
            </div>
          </div>

          <!-- Event Card 3 -->
          <div class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-blue-500/20 to-cyan-600/20 backdrop-blur-sm border border-blue-400/30 hover:border-blue-400/50 transition-all duration-500 hover:scale-105">
            <div class="aspect-[4/3] bg-gradient-to-br from-blue-400/30 to-cyan-500/30 flex items-center justify-center">
              <svg class="w-16 h-16 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-semibold text-blue-200 mb-2">Investor Networking Forum</h3>
              <p class="text-blue-100 text-sm mb-4">Connecting water technology startups with potential investors and partners</p>
              <div class="flex items-center text-blue-300 text-sm">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                May 8, 2024
              </div>
            </div>
          </div>

          <!-- Event Card 4 -->
          <div class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-green-500/20 to-blue-600/20 backdrop-blur-sm border border-green-400/30 hover:border-green-400/50 transition-all duration-500 hover:scale-105">
            <div class="aspect-[4/3] bg-gradient-to-br from-green-400/30 to-blue-500/30 flex items-center justify-center">
              <svg class="w-16 h-16 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-semibold text-green-200 mb-2">Sustainable Agriculture Symposium</h3>
              <p class="text-blue-100 text-sm mb-4">Exploring water-efficient farming techniques and agricultural innovation</p>
              <div class="flex items-center text-green-300 text-sm">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                June 12-14, 2024
              </div>
            </div>
          </div>

          <!-- Event Card 5 -->
          <div class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-purple-500/20 to-pink-600/20 backdrop-blur-sm border border-purple-400/30 hover:border-purple-400/50 transition-all duration-500 hover:scale-105">
            <div class="aspect-[4/3] bg-gradient-to-br from-purple-400/30 to-pink-500/30 flex items-center justify-center">
              <svg class="w-16 h-16 text-purple-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-semibold text-purple-200 mb-2">Youth Water Leadership Camp</h3>
              <p class="text-blue-100 text-sm mb-4">Empowering young leaders to become water advocates and innovators</p>
              <div class="flex items-center text-purple-300 text-sm">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                July 20-26, 2024
              </div>
            </div>
          </div>

          <!-- Event Card 6 -->
          <div class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-orange-500/20 to-red-600/20 backdrop-blur-sm border border-orange-400/30 hover:border-orange-400/50 transition-all duration-500 hover:scale-105">
            <div class="aspect-[4/3] bg-gradient-to-br from-orange-400/30 to-red-500/30 flex items-center justify-center">
              <svg class="w-16 h-16 text-orange-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-semibold text-orange-200 mb-2">Innovation Pitch Competition</h3>
              <p class="text-blue-100 text-sm mb-4">Startups compete for funding and mentorship in water technology</p>
              <div class="flex items-center text-orange-300 text-sm">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                August 15, 2024
              </div>
            </div>
          </div>
        </div>

        <!-- Call to Action -->
        <div class="text-center mt-16">
          <p class="text-lg text-blue-100 mb-8">
            Want to stay updated on upcoming events?
          </p>
          <button class="bg-gradient-to-r from-cyan-500 to-blue-500 hover:from-cyan-600 hover:to-blue-600 text-white font-semibold px-8 py-4 rounded-xl transition-all duration-300 transform hover:scale-105 hover:shadow-lg">
            Subscribe to Events Newsletter
          </button>
        </div>
      </div>
    </section>

    <!-- Upcoming Events Section -->
    <section class="relative py-20 bg-gradient-to-br from-indigo-900 via-blue-900 to-cyan-900 overflow-hidden">
      <!-- Animated Water Background -->
      <AnimatedWaterBackground intensity="subtle" pattern="flowing" />
      
      <div class="relative z-10 max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-medium mb-6 tracking-wide text-cyan-300">
            Upcoming Events
          </h2>
          <p class="text-lg text-blue-100 max-w-3xl mx-auto">
            Mark your calendar for these exciting water innovation events
          </p>
        </div>

        <!-- Timeline of Events -->
        <div class="space-y-8">
          <!-- Event Timeline Item 1 -->
          <div class="flex flex-col md:flex-row items-start md:items-center space-y-4 md:space-y-0 md:space-x-8 p-6 bg-gradient-to-r from-cyan-500/10 to-blue-500/10 backdrop-blur-sm border border-cyan-400/20 rounded-2xl">
            <div class="flex-shrink-0">
              <div class="w-20 h-20 bg-gradient-to-br from-cyan-400 to-blue-500 rounded-full flex items-center justify-center">
                <span class="text-white font-bold text-lg">MAR</span>
              </div>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-semibold text-cyan-200 mb-2">Water Innovation Summit 2024</h3>
              <p class="text-blue-100 mb-3">Join global leaders, innovators, and investors for three days of intensive networking, knowledge sharing, and collaboration opportunities in water technology.</p>
              <div class="flex flex-wrap items-center gap-4 text-sm text-cyan-300">
                <span class="flex items-center">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  March 15-17, 2024
                </span>
                <span class="flex items-center">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  San Francisco, CA
                </span>
                <span class="flex items-center">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  3 Days
                </span>
              </div>
            </div>
            <div class="flex-shrink-0">
              <button class="bg-gradient-to-r from-cyan-500 to-blue-500 hover:from-cyan-600 hover:to-blue-600 text-white font-medium px-6 py-3 rounded-lg transition-all duration-300 transform hover:scale-105">
                Register Now
              </button>
            </div>
          </div>

          <!-- Event Timeline Item 2 -->
          <div class="flex flex-col md:flex-row items-start md:items-center space-y-4 md:space-y-0 md:space-x-8 p-6 bg-gradient-to-r from-indigo-500/10 to-purple-500/10 backdrop-blur-sm border border-indigo-400/20 rounded-2xl">
            <div class="flex-shrink-0">
              <div class="w-20 h-20 bg-gradient-to-br from-indigo-400 to-purple-500 rounded-full flex items-center justify-center">
                <span class="text-white font-bold text-lg">APR</span>
              </div>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-semibold text-indigo-200 mb-2">Community Water Workshop</h3>
              <p class="text-blue-100 mb-3">Learn practical water conservation techniques and sustainable practices that you can implement in your home and community.</p>
              <div class="flex flex-wrap items-center gap-4 text-sm text-indigo-300">
                <span class="flex items-center">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  April 22, 2024
                </span>
                <span class="flex items-center">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  Virtual Event
                </span>
                <span class="flex items-center">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  2 Hours
                </span>
              </div>
            </div>
            <div class="flex-shrink-0">
              <button class="bg-gradient-to-r from-indigo-500 to-purple-500 hover:from-indigo-600 hover:to-purple-600 text-white font-medium px-6 py-3 rounded-lg transition-all duration-300 transform hover:scale-105">
                Join Workshop
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseThemeLayout>
