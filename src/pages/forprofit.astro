---
import BaseThemeLayout from '../layouts/BaseThemeLayout.astro';
import AnimatedWaterBackground from '../components/ui/AnimatedWaterBackground.astro';
---

<BaseThemeLayout>
  <main class="relative min-h-screen">
    <!-- Animated Water Background -->
    <AnimatedWaterBackground intensity="subtle" pattern="flowing" />
    
    <!-- Hero Section -->
    <section class="relative py-20 bg-gradient-to-br from-blue-900 via-indigo-800 to-cyan-900 overflow-hidden">
      <div class="relative z-10 max-w-6xl mx-auto px-6 text-center">
        <h1 class="text-4xl md:text-6xl font-medium mb-8 tracking-wide text-cyan-300">
          For-Profit Initiatives
        </h1>
        <p class="text-xl text-blue-100 max-w-3xl mx-auto leading-relaxed">
          Leveraging market forces, innovation, and scalable business models to create sustainable water solutions.
        </p>
      </div>
    </section>

    <!-- Main Content Section -->
    <section class="relative py-20 bg-gradient-to-br from-indigo-900 via-blue-800 to-cyan-900 overflow-hidden">
      <div class="relative z-10 max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-medium mb-6 tracking-wide text-cyan-300">
            Innovation Through Business
          </h2>
          <p class="text-lg text-blue-100 max-w-3xl mx-auto">
            Our for-profit approach focuses on creating scalable, market-driven solutions that can reach millions 
            of people while maintaining financial sustainability and driving innovation.
          </p>
        </div>

        <!-- Initiatives Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
          <!-- Technology Innovation -->
          <div class="group bg-gradient-to-br from-blue-500/10 to-indigo-500/10 backdrop-blur-sm border border-blue-400/20 rounded-2xl p-6 hover:from-blue-500/20 hover:to-indigo-500/20 transition-all duration-500 hover:scale-105">
            <div class="w-16 h-16 bg-gradient-to-br from-blue-400 to-indigo-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-blue-200 mb-3">Technology Innovation</h3>
            <p class="text-blue-100 text-sm leading-relaxed">
              Developing cutting-edge water technologies and smart monitoring systems.
            </p>
          </div>

          <!-- Investment Solutions -->
          <div class="group bg-gradient-to-br from-indigo-500/10 to-purple-500/10 backdrop-blur-sm border border-indigo-400/20 rounded-2xl p-6 hover:from-indigo-500/20 hover:to-purple-500/20 transition-all duration-500 hover:scale-105">
            <div class="w-16 h-16 bg-gradient-to-br from-indigo-400 to-purple-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-indigo-200 mb-3">Investment Solutions</h3>
            <p class="text-blue-100 text-sm leading-relaxed">
              Creating financial instruments and investment opportunities in water infrastructure.
            </p>
          </div>

          <!-- Infrastructure Development -->
          <div class="group bg-gradient-to-br from-purple-500/10 to-pink-500/10 backdrop-blur-sm border border-purple-400/20 rounded-2xl p-6 hover:from-purple-500/20 hover:to-pink-500/20 transition-all duration-500 hover:scale-105">
            <div class="w-16 h-16 bg-gradient-to-br from-purple-400 to-pink-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-purple-200 mb-3">Infrastructure Development</h3>
            <p class="text-blue-100 text-sm leading-relaxed">
              Building and managing water infrastructure projects with sustainable business models.
            </p>
          </div>

          <!-- Consulting Services -->
          <div class="group bg-gradient-to-br from-pink-500/10 to-red-500/10 backdrop-blur-sm border border-pink-400/20 rounded-2xl p-6 hover:from-pink-500/20 hover:to-red-500/20 transition-all duration-500 hover:scale-105">
            <div class="w-16 h-16 bg-gradient-to-br from-pink-400 to-red-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-pink-200 mb-3">Consulting Services</h3>
            <p class="text-blue-100 text-sm leading-relaxed">
              Providing expert advice on water sustainability and business strategy.
            </p>
          </div>

          <!-- Product Development -->
          <div class="group bg-gradient-to-br from-red-500/10 to-orange-500/10 backdrop-blur-sm border border-red-400/20 rounded-2xl p-6 hover:from-red-500/20 hover:to-orange-500/20 transition-all duration-500 hover:scale-105">
            <div class="w-16 h-16 bg-gradient-to-br from-red-400 to-orange-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-red-200 mb-3">Product Development</h3>
            <p class="text-blue-100 text-sm leading-relaxed">
              Creating innovative water products and solutions for commercial markets.
            </p>
          </div>

          <!-- Market Solutions -->
          <div class="group bg-gradient-to-br from-orange-500/10 to-yellow-500/10 backdrop-blur-sm border border-orange-400/20 rounded-2xl p-6 hover:from-orange-500/20 hover:to-yellow-500/20 transition-all duration-500 hover:scale-105">
            <div class="w-16 h-16 bg-gradient-to-br from-orange-400 to-yellow-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-orange-200 mb-3">Market Solutions</h3>
            <p class="text-blue-100 text-sm leading-relaxed">
              Developing market-based approaches to water challenges and sustainability.
            </p>
          </div>
        </div>

        <!-- Call to Action -->
        <div class="text-center">
          <div class="bg-gradient-to-r from-blue-500/20 to-indigo-500/20 backdrop-blur-sm border border-blue-400/30 rounded-2xl p-8 max-w-2xl mx-auto">
            <h3 class="text-2xl font-semibold text-blue-200 mb-4">
              Partner With Us
            </h3>
            <p class="text-blue-100 mb-6">
              Explore investment opportunities and business partnerships in water sustainability.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <button class="bg-gradient-to-r from-blue-500 to-indigo-500 hover:from-blue-600 hover:to-indigo-600 text-white font-semibold px-8 py-3 rounded-xl transition-all duration-300 transform hover:scale-105 hover:shadow-lg">
                Investment Opportunities
              </button>
              <button class="bg-gradient-to-r from-indigo-500 to-purple-500 hover:from-indigo-600 hover:to-purple-600 text-white font-semibold px-8 py-3 rounded-xl transition-all duration-300 transform hover:scale-105 hover:shadow-lg">
                Business Partnership
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseThemeLayout>
