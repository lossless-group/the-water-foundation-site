---
// New Creative Homepage Variant
import BaseThemeLayout from '../layouts/BaseThemeLayout.astro';
import HeroCenteredLogoMobilePopOut from '../components/basics/heros/HeroCenteredLogo--MobilePopOut.astro';
import BlindSpotStoryVariant4 from '../layouts/sections/core-messages/BlindSpotV4.astro';
import WhoWeAreExtendedV3 from '../layouts/sections/who-we-are/WhoWeAreExtendedV3.astro';
import AtCrisisPoint from '../layouts/sections/core-messages/AtCrisisPoint--Jumbo.astro';
import InvestInTransformation from '../layouts/sections/core-messages/InvestInTransformation--Jumbo.astro';
import SolutionSurge from '../layouts/sections/core-messages/SolutionSurge--Jumbo.astro';
import UnsiloedFinance from '../layouts/sections/core-messages/UnsiloedFinance--Jumbo.astro';
import InnovationToScale from '../layouts/sections/core-messages/InnovationToScale--Jumbo.astro';
import GlobalFootprint from '../layouts/sections/message-grids/GlobalFootprintRowTags.astro';
import ArrowContainer from '../components/infographic/ArrowContainer.astro';
import AnimatedWaterBackground from '../components/ui/AnimatedWaterBackground.astro';
---

<BaseThemeLayout
  title="The Water Foundation - Tackling Humanity's Core Blind Spot"
  description="We bring together exceptional people to tackle water scarcity through innovation, collaboration, and strategic action. Water is the last big scarcity play."
  themeClass="theme-water"
  containerClass="max-w-none mx-auto"
  ogImage="/ogImageLandscape__The-Water-Foundation.jpg"
  ogImagePortrait="/ogImagePortrait__The-Water-Foundation.jpg"
>
  <main class="overflow-x-hidden font-avenir">
    
    <!-- Full-Width Hero Section with Enhanced Animations -->
    <section class="relative overflow-hidden">
      <!-- Animated Background Elements -->
      <div class="absolute inset-0 z-0">
        <!-- Floating Water Particles -->
        <div class="absolute top-20 left-20 w-3 h-3 bg-blue-400/40 rounded-full animate-float opacity-60"></div>
        <div class="absolute top-40 right-32 w-2 h-2 bg-teal-400/40 rounded-full animate-float-delay opacity-40"></div>
        <div class="absolute bottom-32 left-1/4 w-4 h-4 bg-cyan-400/40 rounded-full animate-float-slow opacity-50"></div>
        <div class="absolute top-1/2 right-1/3 w-1 h-1 bg-blue-300/40 rounded-full animate-float-fast opacity-30"></div>
        <div class="absolute top-1/3 left-1/3 w-2 h-2 bg-teal-300/40 rounded-full animate-float-delay-2 opacity-35"></div>
        <div class="absolute bottom-1/3 right-1/4 w-3 h-3 bg-cyan-300/40 rounded-full animate-float-slow-2 opacity-45"></div>
        
        <!-- Gradient Orbs -->
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-gradient-to-br from-blue-600/10 to-transparent rounded-full blur-3xl animate-pulse-slow"></div>
        <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-gradient-to-br from-teal-600/10 to-transparent rounded-full blur-3xl animate-pulse-delay"></div>
        <div class="absolute top-1/2 left-1/2 w-64 h-64 bg-gradient-to-br from-cyan-600/8 to-transparent rounded-full blur-2xl animate-pulse-slow-2"></div>
      </div>

      <!-- Existing Hero Component -->
      <HeroCenteredLogoMobilePopOut 
        contextSetterTxt="Global Impact"
        headerLogoSrc="/trademark__The-Water-Foundation--Darker--Wide.svg"
        headerTxt="Water independence for 1 billion people by 2035"
        subHeaderTxt="Securing our water future through innovation, investment, and impact."
        supportingCopyTxt="The Water Foundation is pioneering a new approach to water security that combines cutting-edge technology, blended & sustainable finance, and networked capital to create lasting solutions."
        targetActionsArray={[
          { 
            text: 'Think with Us', 
            href: '/nerd-out/on-water', 
            type: 'accent',
            size: 'md',
            external: false
          },
          { 
            text: 'Invest with Us', 
            href: '/about', 
            type: 'primary',
            size: 'md',
            external: false
          },
          { 
            text: 'Partner with Us', 
            href: '/partners', 
            type: 'secondary',
            size: 'md',
            external: false
          }
        ]}
        backgroundsArray={[
          { 
            type: 'image', 
            src: '/heroes/imageOf__Whale-pair-under-wave.jpeg',
            overlay: true,
            overlayOpacity: 0.1,
            overlayGradient: 'linear-gradient(135deg, rgba(20, 184, 166, 0.8) 0%, rgba(6, 182, 212, 0.6) 50%, rgba(59, 130, 246, 0.4) 100%)'
          }
        ]}
        paddingClasses="py-8 md:py-12 lg:py-16"
      >
      </HeroCenteredLogoMobilePopOut>
    </section>

    <!-- Enhanced Blind Spot Story -->
    <BlindSpotStoryVariant4 />
    <hr class="my-16 border-t border-border/30 max-w-4xl mx-auto" />

    <!-- Who We Are - Variant 3 -->
    <div>
      <WhoWeAreExtendedV3 />
    </div>

    <!-- Artesians Section - Directly on Homepage -->
    <section class="relative py-20 bg-gradient-to-br from-slate-600 via-blue-600 to-teal-600 overflow-hidden">
      <!-- Animated Water Background -->
      <AnimatedWaterBackground intensity="subtle" pattern="flowing" />
      
      <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
        <p class="text-foreground/80 mb-8 font-avenir text-lg leading-relaxed text-white">
          The Water Foundation's supporters provide us with a <span class="text-cyan-300 font-semibold">strong financial base</span> to <span class="text-cyan-300 font-semibold">accelerate</span> this process. 
        </p>
        
        <div class="text-center mb-8">
          <a href="/about/artesians" class="group inline-block">
            <div class="relative">
              <!-- Enhanced Geometric, interconnected typography inspired by HAUS DER KUNST -->
              <div class="font-light tracking-[0.2em] leading-none">
                <span class="text-2xl text-cyan-300 group-hover:text-cyan-200 transition-colors duration-700 font-light opacity-90 group-hover:opacity-100">Join our</span>
                <div class="mt-2 relative">
                  <span class="text-6xl font-extralight text-cyan-200 group-hover:text-white transition-all duration-1000 tracking-[0.15em] leading-none" style="font-feature-settings: 'liga' 1, 'kern' 1;">
                    Artesians
                  </span>
                  
                  <!-- Subtle geometric accent lines -->
                  <div class="absolute -top-2 -right-2 w-8 h-px bg-gradient-to-r from-cyan-400 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-1000 transform scale-x-0 group-hover:scale-x-100 origin-left"></div>
                  <div class="absolute -bottom-2 -left-2 w-8 h-px bg-gradient-to-r from-transparent to-blue-400 opacity-0 group-hover:opacity-100 transition-all duration-1000 transform scale-x-0 group-hover:scale-x-100 origin-right"></div>
                </div>
              </div>
              
              <!-- Enhanced geometric underline with art deco feel -->
              <div class="mt-4">
                <div class="h-px bg-gradient-to-r from-transparent via-cyan-400 to-transparent opacity-60 group-hover:opacity-100 transition-opacity duration-700"></div>
                <div class="h-px bg-gradient-to-r from-transparent via-blue-400 to-transparent opacity-40 group-hover:opacity-80 transition-opacity duration-700 mt-1"></div>
                <div class="h-px bg-gradient-to-r from-transparent via-teal-400 to-transparent opacity-20 group-hover:opacity-60 transition-opacity duration-700 mt-1"></div>
              </div>
              
              <!-- Enhanced subtitle with geometric spacing and animation -->
              <p class="text-foreground/40 text-sm mt-6 font-extralight tracking-wider opacity-0 group-hover:opacity-100 transition-all duration-1000 transform translate-y-2 group-hover:translate-y-0">
                and become part of the solution
              </p>
              
              <!-- Subtle geometric corner accents -->
              <div class="absolute -top-4 -left-4 w-2 h-2 border-l-2 border-t-2 border-cyan-400/30 opacity-0 group-hover:opacity-100 transition-all duration-700 transform scale-0 group-hover:scale-100"></div>
              <div class="absolute -top-4 -right-4 w-2 h-2 border-r-2 border-t-2 border-blue-400/30 opacity-0 group-hover:opacity-100 transition-all duration-700 transform scale-0 group-hover:scale-100"></div>
              <div class="absolute -bottom-4 -left-4 w-2 h-2 border-l-2 border-b-2 border-teal-400/30 opacity-0 group-hover:opacity-100 transition-all duration-700 transform scale-0 group-hover:scale-100"></div>
              <div class="absolute -bottom-4 -right-4 w-2 h-2 border-r-2 border-b-2 border-cyan-400/30 opacity-0 group-hover:opacity-100 transition-all duration-700 transform scale-0 group-hover:scale-100"></div>
            </div>
          </a>
        </div>

        <!-- Non For Profit / For Profit Cards -->
        <div class="grid md:grid-cols-2 gap-8">
          <div class="group transform transition-all duration-500 hover:scale-105">
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8 h-full hover:bg-white/10 hover:border-white/20 transition-all duration-500">
              <h3 class="text-2xl font-light text-teal-300 mb-4">Non For Profit</h3>
              <p class="text-blue-100 leading-relaxed font-light">
                We accept donations and employ best practices in blended finance for development and impact, enabling us to drive sustainable change through charitable initiatives and strategic partnerships.
              </p>
            </div>
          </div>
          
          <div class="group transform transition-all duration-500 hover:scale-105">
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8 h-full hover:bg-white/10 hover:border-white/20 transition-all duration-500">
              <h3 class="text-2xl font-light text-cyan-300 mb-4">For Profit</h3>
              <p class="text-blue-100 leading-relaxed font-light">
                We accept direct capital investments into closed-end venture and PE funds, as well as participate with our principals in an evergreen structure, creating opportunities for financial returns alongside impact.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Elegant Investment Opportunity Section -->
    <section class="relative py-24 bg-gradient-to-br from-slate-800 via-blue-800 to-teal-800 overflow-hidden">
      <!-- Subtle Background Pattern -->
      <div class="absolute inset-0 opacity-5">
        <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 25%, white 1px, transparent 1px), radial-gradient(circle at 75% 75%, white 1px, transparent 1px); background-size: 50px 50px;"></div>
      </div>
      
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-20">
          <!-- Elegant Divider -->
          <div class="w-32 h-px bg-gradient-to-r from-transparent via-blue-400 to-transparent mx-auto mb-8"></div>
          
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-light text-white mb-8 tracking-wide">
            The <span class="text-cyan-300 font-normal">Investment Opportunity</span> of Our Time
          </h2>
          <p class="text-xl text-blue-200 max-w-3xl mx-auto font-light leading-relaxed">
            Water is the last big scarcity play - where innovation meets impact meets returns
          </p>
          
          <!-- Elegant Divider -->
          <div class="w-32 h-px bg-gradient-to-r from-transparent via-blue-400 to-transparent mx-auto mt-8"></div>
        </div>
        
        <!-- Elegant Investment Metrics -->
        <div class="grid md:grid-cols-3 gap-10 mb-20">
          <div class="group transform transition-all duration-700 hover:scale-105 hover:-translate-y-3">
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-10 h-full hover:bg-white/10 hover:border-white/20 transition-all duration-700">
              <div class="text-5xl font-light text-cyan-300 mb-4">$1T+</div>
              <h3 class="text-xl font-light text-white mb-4 tracking-wide">Water Tech Market by 2030</h3>
              <p class="text-blue-200 text-sm font-light leading-relaxed">Global water technology market projected to exceed USD 1 trillion</p>
            </div>
          </div>
          
          <div class="group transform transition-all duration-700 hover:scale-105 hover:-translate-y-3">
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-10 h-full hover:bg-white/10 hover:border-white/20 transition-all duration-700">
              <div class="text-5xl font-light text-blue-300 mb-4">$114B</div>
              <h3 class="text-xl font-light text-white mb-4 tracking-wide">Annual Investment Gap</h3>
              <p class="text-blue-200 text-sm font-light leading-relaxed">Required annually until 2030 to achieve SDG 6</p>
            </div>
          </div>
          
          <div class="group transform transition-all duration-700 hover:scale-105 hover:-translate-y-3">
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-10 h-full hover:bg-white/10 hover:border-white/20 transition-all duration-700">
              <div class="text-5xl font-light text-teal-300 mb-4">300K+</div>
              <h3 class="text-xl font-light text-white mb-4 tracking-wide">Lives at Risk Annually</h3>
              <p class="text-blue-200 text-sm font-light leading-relaxed">Children under 5 die from water-related diseases</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Creative Call to Action -->
    <section class="relative py-24 bg-gradient-to-br from-slate-900 via-blue-900 to-teal-900 overflow-hidden">
      <!-- Animated Water Background -->
      <AnimatedWaterBackground intensity="subtle" pattern="scattered" />
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-light text-white mb-8 tracking-wide">
          Ready to <span class="text-cyan-300 font-normal">Act</span>?
        </h2>
        <p class="text-xl text-blue-100 mb-12 max-w-2xl mx-auto font-light">
          Join us in tackling humanity's core blind spot. Water is the last big scarcity play - and the time to act is now.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-8 justify-center items-center">
          <!-- Learn More Button - Morphing Blob -->
          <a href="/about" class="group relative">
            <div class="relative">
              <!-- Main Button Container -->
              <div class="relative px-12 py-6 bg-gradient-to-r from-blue-600 to-teal-600 text-white font-light text-xl overflow-hidden transition-all duration-700 transform hover:scale-110">
                <!-- Base Blob Shape -->
                <div class="absolute inset-0 bg-gradient-to-r from-blue-600 to-teal-600 blob-shape-1"></div>
                
                <!-- Layered Organic Elements -->
                <div class="absolute top-2 left-2 w-4 h-4 bg-white/20 rounded-full animate-pulse"></div>
                <div class="absolute top-2 right-2 w-3 h-3 bg-cyan-300/40 rounded-full animate-pulse" style="animation-delay: 0.5s;"></div>
                <div class="absolute bottom-2 left-2 w-3 h-3 bg-blue-300/40 rounded-full animate-pulse" style="animation-delay: 1s;"></div>
                <div class="absolute bottom-2 right-2 w-4 h-4 bg-white/20 rounded-full animate-pulse" style="animation-delay: 1.5s;"></div>
                
                <!-- Floating Detached Blobs -->
                <div class="absolute -top-3 -left-3 w-6 h-6 bg-cyan-400/60 blob-float-1 animate-float-slow group-hover:scale-125 group-hover:blob-morph-1 transition-all duration-700"></div>
                <div class="absolute -top-2 -right-2 w-4 h-4 bg-blue-400/60 blob-float-2 animate-float-delay group-hover:scale-150 group-hover:-translate-x-2 transition-all duration-700"></div>
                <div class="absolute -bottom-3 -right-3 w-5 h-5 bg-teal-400/60 blob-float-3 animate-float-slow-2 group-hover:scale-125 group-hover:blob-morph-2 transition-all duration-700"></div>
                
                <!-- Text -->
                <span class="relative z-10">Learn More</span>
              </div>
            </div>
          </a>
          
          <!-- Get Involved Button - Morphing Blob -->
          <a href="/nerd-out/on-water" class="group relative">
            <div class="relative">
              <!-- Main Button Container -->
              <div class="relative px-12 py-6 border-2 border-cyan-400 text-cyan-300 font-light text-xl overflow-hidden transition-all duration-700 transform hover:scale-110">
                <!-- Base Blob Shape -->
                <div class="absolute inset-0 bg-gradient-to-r from-cyan-500/10 to-blue-500/10 blob-shape-2"></div>
                
                <!-- Layered Organic Elements -->
                <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-cyan-400/30 rounded-full animate-pulse"></div>
                <div class="absolute top-1/4 left-1/4 w-3 h-3 bg-blue-400/20 rounded-full animate-pulse" style="animation-delay: 0.3s;"></div>
                <div class="absolute top-1/4 right-1/4 w-2 h-2 bg-cyan-400/30 rounded-full animate-pulse" style="animation-delay: 0.6s;"></div>
                <div class="absolute bottom-1/4 left-1/4 w-2 h-2 bg-blue-400/20 rounded-full animate-pulse" style="animation-delay: 0.9s;"></div>
                <div class="absolute bottom-1/4 right-1/4 w-3 h-3 bg-cyan-400/30 rounded-full animate-pulse" style="animation-delay: 1.2s;"></div>
                
                <!-- Floating Detached Blobs -->
                <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 w-4 h-4 bg-cyan-400/50 blob-float-4 animate-float-fast group-hover:scale-150 group-hover:-translate-y-1 transition-all duration-700"></div>
                <div class="absolute top-1/2 -left-4 w-3 h-3 bg-blue-400/40 blob-float-5 animate-float-delay-2 group-hover:scale-125 group-hover:translate-x-1 transition-all duration-700"></div>
                <div class="absolute top-1/2 -right-4 w-3 h-3 bg-cyan-400/40 blob-float-6 animate-float-delay-2 group-hover:scale-125 group-hover:-translate-x-1 transition-all duration-700"></div>
                <div class="absolute -bottom-4 left-1/2 transform -translate-x-1/2 w-4 h-4 bg-blue-400/50 blob-float-7 animate-float-slow group-hover:scale-150 group-hover:translate-y-1 transition-all duration-700"></div>
                
                <!-- Text -->
                <span class="relative z-10">Get Involved</span>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- We Commit to Tangible Change Section -->
    <section class="relative py-24 bg-gradient-to-br from-blue-900 via-indigo-800 to-purple-900 overflow-hidden">
      <!-- Animated Water Background -->
      <AnimatedWaterBackground intensity="subtle" pattern="flowing" />
      
      <div class="relative z-10 max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Left Column: Image -->
          <div class="relative">
            <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-cyan-400/30 shadow-2xl">
              <!-- Actual photo -->
              <img 
                src="/heroes/imageOf__Christoph-and-colleague-blue-economy-forum.jpeg" 
                alt="Christoph Schnager and colleague at the Blue Economy & Finance Forum, Monaco 2025" 
                class="w-full h-full object-cover"
              />
              <!-- Photo overlay with "View Full Size" button -->
              <div class="absolute inset-0 bg-black/40 opacity-0 hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <button class="bg-white/20 backdrop-blur-sm text-white px-4 py-2 rounded-lg border border-white/30 hover:bg-white/30 transition-all duration-300">
                  View Full Size
                </button>
              </div>
            </div>
          </div>

          <!-- Right Column: Text Content -->
          <div class="text-left">
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-8 leading-tight">
              We commit to <span class="text-cyan-300">tangible change</span>
            </h2>
            
            <p class="text-xl text-blue-100 mb-8 leading-relaxed font-light">
              We want to create real and measurable transformations. To achieve this, we connect the brightest minds, 
              set priorities, provide action impulses, and thus create sustainable and effective results.
            </p>
            
            <!-- Call to Action Button -->
            <a href="/about" class="inline-flex items-center space-x-3 bg-gradient-to-r from-cyan-500 to-blue-500 hover:from-cyan-600 hover:to-blue-600 text-white font-semibold px-8 py-4 rounded-2xl transition-all duration-300 transform hover:scale-105 hover:shadow-lg">
              <span>About The Water Foundation</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseThemeLayout>

<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(180deg);
    }
  }
  
  @keyframes float-delay {
    0%, 100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-15px) rotate(180deg);
    }
  }
  
  @keyframes float-slow {
    0%, 100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-30px) rotate(180deg);
    }
  }
  
  @keyframes float-fast {
    0%, 100% {
      transform: translateY(0px) rotate(0deg);
    }
    25% {
      transform: translateY(-25px) rotate(90deg);
    }
    50% {
      transform: translateY(-10px) rotate(180deg);
    }
    75% {
      transform: translateY(-35px) rotate(270deg);
    }
  }
  
  @keyframes float-delay-2 {
    0%, 100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-18px) rotate(180deg);
    }
  }
  
  @keyframes float-slow-2 {
    0%, 100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-22px) rotate(180deg);
    }
  }
  
  @keyframes pulse-slow {
    0%, 100% {
      opacity: 0.1;
      transform: scale(1);
    }
    50% {
      opacity: 0.2;
      transform: scale(1.05);
    }
  }
  
  @keyframes pulse-delay {
    0%, 100% {
      opacity: 0.1;
      transform: scale(1);
    }
    50% {
      opacity: 0.2;
      transform: scale(1.05);
    }
  }
  
  @keyframes pulse-slow-2 {
    0%, 100% {
      opacity: 0.08;
      transform: scale(1);
    }
    50% {
      opacity: 0.15;
      transform: scale(1.03);
    }
  }
  
  /* Interactive Button Shapes */
  .blob-shape-1 {
    border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
    transition: border-radius 0.7s ease-in-out;
  }
  
  .blob-shape-2 {
    border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
    transition: border-radius 0.7s ease-in-out;
  }
  
  .blob-float-1 {
    border-radius: 50% 50% 50% 50% / 60% 40% 60% 40%;
    transition: border-radius 0.7s ease-in-out;
  }
  
  .blob-float-2 {
    border-radius: 40% 60% 40% 60% / 50% 50% 50% 50%;
    transition: border-radius 0.7s ease-in-out;
  }
  
  .blob-float-3 {
    border-radius: 60% 40% 60% 40% / 40% 60% 40% 60%;
    transition: border-radius 0.7s ease-in-out;
  }
  
  .blob-float-4 {
    border-radius: 50% 50% 50% 50% / 40% 60% 40% 60%;
    transition: border-radius 0.7s ease-in-out;
  }
  
  .blob-float-5 {
    border-radius: 60% 40% 60% 40% / 50% 50% 50% 50%;
    transition: border-radius 0.7s ease-in-out;
  }
  
  .blob-float-6 {
    border-radius: 40% 60% 40% 60% / 60% 40% 60% 40%;
    transition: border-radius 0.7s ease-in-out;
  }
  
  .blob-float-7 {
    border-radius: 50% 50% 50% 50% / 60% 40% 60% 40%;
    transition: border-radius 0.7s ease-in-out;
  }
  
  .blob-morph-1 {
    border-radius: 70% 30% 30% 70% / 60% 40% 60% 40%;
  }
  
  .blob-morph-2 {
    border-radius: 40% 60% 60% 40% / 40% 60% 40% 60%;
  }
  
  /* Button Hover Effects */
  .group:hover .blob-shape-1 {
    border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
  }
  
  .group:hover .blob-shape-2 {
    border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
  }
  
  .wave-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
      radial-gradient(circle at 70% 30%, rgba(59, 130, 246, 0.1) 0%, transparent 30%),
