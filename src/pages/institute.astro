---
import BaseThemeLayout from '@layouts/BaseThemeLayout.astro';
import InstituteGlobalPartnersSpan from '@components/institute/InstituteGlobalPartnersSpan.astro';
---

<BaseThemeLayout
  title="TWF Institute - The Water Foundation"
  description="The strategic and policy arm of The Water Foundation. Strategy. Policy. Execution."
  ogImage="/ogImageLandscape__The-Water-Foundation.jpg"
  ogImagePortrait="/ogImagePortrait__The-Water-Foundation.jpg"
>
  <main class="min-h-screen bg-linear-to-b from-background to-background/50">
    <section class="relative py-20 md:py-24 lg:py-32 bg-linear-to-br from-slate-900 via-blue-900 to-teal-900 overflow-hidden">
      <div class="absolute inset-0">
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-linear-to-br from-blue-600/20 to-transparent rounded-full blur-3xl animate-pulse-slow"></div>
        <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-linear-to-br from-teal-600/15 to-transparent rounded-full blur-3xl animate-pulse-delay"></div>
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-linear-to-br from-cyan-600/10 to-transparent rounded-full blur-3xl animate-pulse-slow"></div>
      </div>

      <div class="absolute inset-0 opacity-5">
        <div class="w-full h-full" style="background-image: linear-gradient(rgba(59, 130, 246, 0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(59, 130, 246, 0.3) 1px, transparent 1px); background-size: 50px 50px;"></div>
      </div>

      <div class="relative z-10 max-w-6xl mx-auto px-6 text-center">
        <div class="mb-10">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-light text-white mb-6 tracking-wide">
            TWF <span class="text-cyan-300 font-normal">INSTITUTE</span>
          </h1>
          <p class="text-xl md:text-2xl text-white/90 max-w-4xl mx-auto leading-relaxed font-light">
            Strategy. Policy. Execution.
          </p>
        </div>

        <div class="max-w-4xl mx-auto">
          <div class="rounded-3xl border border-white/20 bg-white/10 backdrop-blur-xl px-8 py-8 text-left">
            <h2 class="text-2xl md:text-3xl font-light text-white mb-4 tracking-wide">Overview</h2>
            <p class="text-white/90 leading-relaxed">
              The TWF Institute is the strategic and policy arm of The Water Foundation.
            </p>
            <p class="text-white/90 leading-relaxed mt-4">
              We operate at the intersection of government advisory, capital structuring, and systems-level implementation, translating water risk into sovereign strategy, investable frameworks, and deployable solutions.
            </p>
            <p class="text-white/90 leading-relaxed mt-4">
              While grounded in rigorous research and thought leadership, the Institute is explicitly execution-oriented. We do not stop at analysis—we design, structure, and support the implementation of national, regional, and basin-level water strategies.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-20">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-1 gap-8">
          <div class="rounded-3xl border border-border/20 bg-card/40 backdrop-blur-sm p-8">
            <h2 class="text-2xl md:text-3xl font-light text-foreground mb-4 tracking-wide">Positioning</h2>
            <p class="text-foreground/80 leading-relaxed">
              Water is no longer an environmental issue. It is a sovereignty variable, a security constraint, and a capital allocation problem.
            </p>
            <p class="text-foreground/80 leading-relaxed mt-4">
              The TWF Institute was built to address this shift.
            </p>

            <div class="mt-6 rounded-2xl border border-border/20 bg-background/40 p-6">
              <p class="text-foreground/80 leading-relaxed mb-4">
                We work with governments, family offices, multilaterals, and corporates to:
              </p>
              <ul class="list-disc list-outside pl-5 space-y-2 text-foreground/80">
                <li>Integrate water into national security and economic planning</li>
                <li>Translate hydrological risk into financial and strategic decision-making</li>
                <li>Build institutional capacity for hydro-diplomacy and basin governance</li>
                <li>Mobilise capital through bankable, structured investment frameworks</li>
              </ul>
            </div>
          </div>

          <div class="rounded-3xl border border-border/20 bg-card/40 backdrop-blur-sm p-8">
            <h2 class="text-2xl md:text-3xl font-light text-foreground mb-6 tracking-wide">What We Do</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="rounded-3xl border border-border/20 bg-background/40 p-6">
                <h3 class="text-lg font-medium text-foreground mb-3">1. Government &amp; Sovereign Advisory</h3>
                <p class="text-foreground/80 leading-relaxed mb-4">We advise governments and public institutions on:</p>
                <ul class="list-disc list-outside pl-5 space-y-2 text-foreground/80">
                  <li>National Hydro-Security Strategies</li>
                  <li>Water integration into defence, infrastructure, and economic policy</li>
                  <li>Transboundary water governance and basin diplomacy</li>
                  <li>Institutional architecture for water resilience and independence</li>
                </ul>
                <div class="mt-5 pt-5 border-t border-border/20">
                  <p class="text-foreground/80 leading-relaxed mb-3">Output formats include:</p>
                  <ul class="list-disc list-outside pl-5 space-y-2 text-foreground/80">
                    <li>Strategic white papers</li>
                    <li>Policy frameworks and legislative input</li>
                    <li>Cabinet-level briefing materials</li>
                    <li>Implementation roadmaps</li>
                  </ul>
                </div>
              </div>

              <div class="rounded-3xl border border-border/20 bg-background/40 p-6">
                <h3 class="text-lg font-medium text-foreground mb-3">2. Capital &amp; Investment Structuring</h3>
                <p class="text-foreground/80 leading-relaxed mb-4">We design and operationalise capital strategies aligned with water resilience:</p>
                <ul class="list-disc list-outside pl-5 space-y-2 text-foreground/80">
                  <li>National and regional water investment platforms</li>
                  <li>Blended finance structures across public–private capital stacks</li>
                  <li>Development of water as an asset class</li>
                  <li>Structuring of VC, PE, and infrastructure vehicles</li>
                </ul>
                <p class="text-foreground/80 leading-relaxed mt-5 pt-5 border-t border-border/20">
                  This includes close integration with TWF’s investment vehicles and partners.
                </p>
              </div>

              <div class="rounded-3xl border border-border/20 bg-background/40 p-6">
                <h3 class="text-lg font-medium text-foreground mb-3">3. Systems &amp; Infrastructure Strategy</h3>
                <p class="text-foreground/80 leading-relaxed mb-4">We work on system-level design, not isolated interventions:</p>
                <ul class="list-disc list-outside pl-5 space-y-2 text-foreground/80">
                  <li>Basin-level planning across energy–water–food systems</li>
                  <li>Infrastructure prioritisation under scarcity and volatility scenarios</li>
                  <li>Deployment strategies for water technology ecosystems</li>
                  <li>Urban and industrial resilience frameworks</li>
                </ul>
              </div>

              <div class="rounded-3xl border border-border/20 bg-background/40 p-6">
                <h3 class="text-lg font-medium text-foreground mb-3">4. Thought Leadership &amp; Strategic Foresight</h3>
                <p class="text-foreground/80 leading-relaxed mb-4">The Institute develops core intellectual frameworks shaping the field:</p>
                <ul class="list-disc list-outside pl-5 space-y-2 text-foreground/80">
                  <li>The Hydro-Security Paradigm</li>
                  <li>Liquid Geopolitics</li>
                  <li>The Water Score (sovereign and asset-level assessment framework)</li>
                </ul>
                <div class="mt-5 pt-5 border-t border-border/20">
                  <p class="text-foreground/80 leading-relaxed mb-3">Outputs include:</p>
                  <ul class="list-disc list-outside pl-5 space-y-2 text-foreground/80">
                    <li>Flagship reports (e.g. Munich Security Conference publications)</li>
                    <li>Closed-door policy briefings</li>
                    <li>Strategic convenings and high-level roundtables</li>
                    <li>Scenario analysis for decision-makers</li>
                  </ul>
                </div>
              </div>

              <div class="rounded-3xl border border-border/20 bg-background/40 p-6 md:col-span-2">
                <h3 class="text-lg font-medium text-foreground mb-3">5. Execution &amp; Embedded Advisory</h3>
                <p class="text-foreground/80 leading-relaxed mb-4">Beyond strategy, we support implementation on the ground:</p>
                <ul class="list-disc list-outside pl-5 space-y-2 text-foreground/80 md:columns-2">
                  <li>Acting as embedded advisors within governments and institutions</li>
                  <li>Supporting execution of national programmes and investment vehicles</li>
                  <li>Partnering on pilot deployments and regional initiatives</li>
                  <li>Coordinating across public, private, and philanthropic stakeholders</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="rounded-3xl border border-border/20 bg-card/40 backdrop-blur-sm p-8">
            <h2 class="text-2xl md:text-3xl font-light text-foreground mb-4 tracking-wide">Operating Model</h2>
            <p class="text-foreground/80 leading-relaxed mb-6">
              The TWF Institute operates through a federated partner structure.
            </p>

            <div class="rounded-2xl border border-border/20 bg-background/40 p-6">
              <h3 class="text-lg font-medium text-foreground mb-3">Global Partners</h3>
              <p class="text-foreground/80 leading-relaxed mb-4">
                Provide strategic direction, intellectual leadership, and platform integration:
              </p>
              <InstituteGlobalPartnersSpan />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseThemeLayout>
