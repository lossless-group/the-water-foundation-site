---
import BaseThemeLayout from '../layouts/BaseThemeLayout.astro';
import AnimatedWaterBackground from '../components/ui/AnimatedWaterBackground.astro';
---

<BaseThemeLayout>
  <main class="relative min-h-screen">
    <!-- Animated Water Background -->
    <AnimatedWaterBackground intensity="subtle" pattern="flowing" />
    
    <!-- Hero Section -->
    <section class="relative py-20 bg-gradient-to-br from-cyan-900 via-blue-800 to-indigo-900 overflow-hidden">
      <div class="relative z-10 max-w-6xl mx-auto px-6 text-center">
        <h1 class="text-4xl md:text-6xl font-medium mb-8 tracking-wide text-cyan-300">
          Non-Profit Initiatives
        </h1>
        <p class="text-xl text-blue-100 max-w-3xl mx-auto leading-relaxed">
          Driving social impact through community engagement, education, and grassroots change in water sustainability.
        </p>
      </div>
    </section>

    <!-- Main Content Section -->
    <section class="relative py-20 bg-gradient-to-br from-blue-900 via-indigo-800 to-cyan-900 overflow-hidden">
      <div class="relative z-10 max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-medium mb-6 tracking-wide text-cyan-300">
            Community-Driven Solutions
          </h2>
          <p class="text-lg text-blue-100 max-w-3xl mx-auto">
            Our non-profit approach focuses on building strong communities, raising awareness, 
            and creating lasting change through education and grassroots initiatives.
          </p>
        </div>

        <!-- Initiatives Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
          <!-- Educational Programs -->
          <div class="group bg-gradient-to-br from-cyan-500/10 to-blue-500/10 backdrop-blur-sm border border-cyan-400/20 rounded-2xl p-6 hover:from-cyan-500/20 hover:to-blue-500/20 transition-all duration-500 hover:scale-105">
            <div class="w-16 h-16 bg-gradient-to-br from-cyan-400 to-blue-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-cyan-200 mb-3">Educational Programs</h3>
            <p class="text-blue-100 text-sm leading-relaxed">
              Comprehensive water education initiatives for schools, communities, and organizations.
            </p>
          </div>

          <!-- Community Outreach -->
          <div class="group bg-gradient-to-br from-blue-500/10 to-indigo-500/10 backdrop-blur-sm border border-blue-400/20 rounded-2xl p-6 hover:from-blue-500/20 hover:to-indigo-500/20 transition-all duration-500 hover:scale-105">
            <div class="w-16 h-16 bg-gradient-to-br from-blue-400 to-indigo-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-blue-200 mb-3">Community Outreach</h3>
            <p class="text-blue-100 text-sm leading-relaxed">
              Direct engagement with local communities to address water challenges and build awareness.
            </p>
          </div>

          <!-- Advocacy & Awareness -->
          <div class="group bg-gradient-to-br from-indigo-500/10 to-purple-500/10 backdrop-blur-sm border border-indigo-400/20 rounded-2xl p-6 hover:from-indigo-500/20 hover:to-purple-500/20 transition-all duration-500 hover:scale-105">
            <div class="w-16 h-16 bg-gradient-to-br from-indigo-400 to-purple-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3.14A3.97 3.97 0 0017 3c-.764 0-1.497.212-2.168.588M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3.14A3.97 3.97 0 0017 3c-.764 0-1.497.212-2.168.588"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-indigo-200 mb-3">Advocacy & Awareness</h3>
            <p class="text-blue-100 text-sm leading-relaxed">
              Campaigns and initiatives to raise awareness about water sustainability and conservation.
            </p>
          </div>

          <!-- Volunteer Programs -->
          <div class="group bg-gradient-to-br from-purple-500/10 to-pink-500/10 backdrop-blur-sm border border-purple-400/20 rounded-2xl p-6 hover:from-purple-500/20 hover:to-pink-500/20 transition-all duration-500 hover:scale-105">
            <div class="w-16 h-16 bg-gradient-to-br from-purple-400 to-pink-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-purple-200 mb-3">Volunteer Programs</h3>
            <p class="text-blue-100 text-sm leading-relaxed">
              Opportunities for individuals to contribute their time and skills to water sustainability projects.
            </p>
          </div>

          <!-- Research & Documentation -->
          <div class="group bg-gradient-to-br from-pink-500/10 to-red-500/10 backdrop-blur-sm border border-pink-400/20 rounded-2xl p-6 hover:from-pink-500/20 hover:to-red-500/20 transition-all duration-500 hover:scale-105">
            <div class="w-16 h-16 bg-gradient-to-br from-pink-400 to-red-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-pink-200 mb-3">Research & Documentation</h3>
            <p class="text-blue-100 text-sm leading-relaxed">
              Gathering data and documenting water challenges to inform policy and community action.
            </p>
          </div>

          <!-- Partnerships -->
          <div class="group bg-gradient-to-br from-red-500/10 to-orange-500/10 backdrop-blur-sm border border-red-400/20 rounded-2xl p-6 hover:from-red-500/20 hover:to-orange-500/20 transition-all duration-500 hover:scale-105">
            <div class="w-16 h-16 bg-gradient-to-br from-red-400 to-orange-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-red-200 mb-3">Partnerships</h3>
            <p class="text-blue-100 text-sm leading-relaxed">
              Collaborating with other non-profits, schools, and community organizations.
            </p>
          </div>
        </div>

        <!-- Call to Action -->
        <div class="text-center">
          <div class="bg-gradient-to-r from-cyan-500/20 to-blue-500/20 backdrop-blur-sm border border-cyan-400/30 rounded-2xl p-8 max-w-2xl mx-auto">
            <h3 class="text-2xl font-semibold text-cyan-200 mb-4">
              Get Involved
            </h3>
            <p class="text-blue-100 mb-6">
              Join our non-profit initiatives and help create lasting change in water sustainability.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <button class="bg-gradient-to-r from-cyan-500 to-blue-500 hover:from-cyan-600 hover:to-blue-600 text-white font-semibold px-8 py-3 rounded-xl transition-all duration-300 transform hover:scale-105 hover:shadow-lg">
                Volunteer Now
              </button>
              <button class="bg-gradient-to-r from-blue-500 to-indigo-500 hover:from-blue-600 hover:to-indigo-600 text-white font-semibold px-8 py-3 rounded-xl transition-all duration-300 transform hover:scale-105 hover:shadow-lg">
                Learn More
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseThemeLayout>
